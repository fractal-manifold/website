---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ResearchSection from '../components/sections/ResearchSection.astro';
import FoundersSection from '../components/sections/FoundersSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
---

<Layout title="Fractal Manifold - Deep Learning Research & Investment">
  <Fragment slot="head">
    <link rel="stylesheet" href="/katex/katex.min.css" />
  </Fragment>
  <Header />

  <main id="main-content">
    <HeroSection />
    <ResearchSection />
    <FoundersSection />
    <ContactSection />
  </main>

  <Footer />
</Layout>

<style>
  main {
    padding-top: 80px;
    width: 100%;
    overflow-x: hidden;
  }

  @media (max-width: 768px) {
    main {
      padding-top: 70px;
    }
  }

  @media (max-width: 480px) {
    main {
      padding-top: 60px;
    }
  }
</style>
