<script is:inline>
// ══════════════════════════════════════════════════════════════
// GLOBAL STATE
// ══════════════════════════════════════════════════════════════
var ALPHA = 0.80;
var calibrationTimer = null;
var STORAGE_KEY = 'fm_investment_model';

// Board state: { order: [rank1, rank2, ...], states: { rank: 'unknown'|'waiting'|'invested'|'canceled' } }
var boardState = { order: [], states: {} };

function getParams() {
  return {
    N: +document.getElementById('paramN').value,
    K: +document.getElementById('paramK').value,
    pMin: +document.getElementById('paramPMin').value,
    pMax: +document.getElementById('paramPMax').value,
    beta: +document.getElementById('paramBeta').value,
    lambda: +document.getElementById('paramLambda').value
  };
}

// ══════════════════════════════════════════════════════════════
// CORE FUNCTIONS
// ══════════════════════════════════════════════════════════════
function dropProb(j, n, pMin, pMax, beta) {
  if (n <= 0) return pMin;
  return pMin + (pMax - pMin) * (Math.exp(beta * j / n) - 1) / (Math.exp(beta) - 1);
}
function expSup(n, pMin, pMax, beta) {
  var s = 0; for (var j = 1; j <= n; j++) s += 1 - dropProb(j, n, pMin, pMax, beta); return s;
}
function companyValue(r, N, lambda) { return Math.exp(lambda * (N - r)); }

function computeThreshold(N, K, remaining, picksNeeded, pMin, pMax, beta, alpha) {
  if (alpha === undefined) alpha = ALPHA;
  if (picksNeeded <= 0) return { threshold: 0, slack: Infinity, urgency: 0, es: 0 };
  if (remaining <= 0) return { threshold: N, slack: 0, urgency: 1, es: 0 };
  if (picksNeeded >= remaining) return { threshold: N, slack: 0, urgency: 1, es: remaining };
  var es = expSup(remaining - 1, pMin, pMax, beta);
  var slack = es - (picksNeeded - 1);
  var urgency = Math.max(0, Math.min(1, 1 - slack / Math.max(picksNeeded, 1)));
  var t;
  if (slack <= 0) { t = N; }
  else { t = Math.ceil(N * picksNeeded / (picksNeeded + slack * alpha)); t = Math.min(N, Math.max(picksNeeded, t)); }
  return { threshold: t, slack: Math.max(0, slack), urgency: urgency, es: es };
}

// ══════════════════════════════════════════════════════════════
// MONTE CARLO CALIBRATION
// ══════════════════════════════════════════════════════════════
function calibrateAlpha() {
  var p = getParams(); var N = p.N, K = p.K, pMin = p.pMin, pMax = p.pMax, beta = p.beta, lambda = p.lambda;
  document.getElementById('calIndicator').classList.add('active');
  setTimeout(function() {
    var bestA = 0.8, bestS = -Infinity;
    for (var a = 0.2; a <= 3.01; a += 0.1) {
      var alpha = Math.round(a * 100) / 100; var totalVal = 0, completed = 0;
      for (var sim = 0; sim < 2000; sim++) {
        var order = []; for (var i = 1; i <= N; i++) order.push(i);
        for (var i = order.length - 1; i > 0; i--) { var j = Math.floor(Math.random() * (i + 1)); var tmp = order[i]; order[i] = order[j]; order[j] = tmp; }
        var acc = [], canc = 0;
        for (var i = 0; i < order.length && acc.length < K; i++) {
          var rem = N - acc.length - canc;
          if (Math.random() < dropProb(1, rem, pMin, pMax, beta)) { canc++; continue; }
          var th = computeThreshold(N, K, rem, K - acc.length, pMin, pMax, beta, alpha).threshold;
          if (order[i] <= th) acc.push(order[i]); else canc++;
        }
        var val = 0; for (var k = 0; k < acc.length; k++) val += companyValue(acc[k], N, lambda);
        totalVal += val; if (acc.length >= K) completed++;
      }
      var score = (totalVal / 2000) * (completed / 2000);
      if (score > bestS) { bestS = score; bestA = alpha; }
    }
    ALPHA = bestA;
    document.getElementById('calIndicator').classList.remove('active');
    computeDecision();
  }, 30);
}

// ══════════════════════════════════════════════════════════════
// BOARD — State management
// ══════════════════════════════════════════════════════════════
function initBoard(N) {
  boardState.order = [];
  boardState.states = {};
  for (var i = 1; i <= N; i++) {
    boardState.order.push(i);
    boardState.states[i] = 'unknown';
  }
}

function resizeBoard(newN) {
  var oldN = boardState.order.length;
  if (newN === oldN) return;
  if (newN > oldN) {
    for (var i = oldN + 1; i <= newN; i++) { boardState.order.push(i); boardState.states[i] = 'unknown'; }
  } else {
    // Remove ranks > newN
    boardState.order = boardState.order.filter(function(r) { return r <= newN; });
    var newStates = {};
    for (var i = 0; i < boardState.order.length; i++) { newStates[boardState.order[i]] = boardState.states[boardState.order[i]] || 'unknown'; }
    boardState.states = newStates;
  }
}

function getBoardStats() {
  var invested = 0, canceled = 0, waiting = 0, unknown = 0, currentRank = null;
  var investedRanks = [];
  for (var i = 0; i < boardState.order.length; i++) {
    var r = boardState.order[i];
    var s = boardState.states[r] || 'unknown';
    if (s === 'invested') { invested++; investedRanks.push(r); }
    else if (s === 'canceled') { canceled++; }
    else if (s === 'waiting') { waiting++; }
    else { unknown++; if (currentRank === null) currentRank = r; }
  }
  return { invested: invested, canceled: canceled, waiting: waiting, unknown: unknown, currentRank: currentRank, investedRanks: investedRanks };
}

function cycleTileState(rank) {
  var current = boardState.states[rank] || 'unknown';
  var cycle = ['unknown', 'waiting', 'invested', 'canceled'];
  var idx = cycle.indexOf(current);
  boardState.states[rank] = cycle[(idx + 1) % cycle.length];
  saveState();
  renderBoard();
  computeDecision();
}

// ══════════════════════════════════════════════════════════════
// BOARD — Rendering
// ══════════════════════════════════════════════════════════════
function renderBoard() {
  var grid = document.getElementById('boardGrid');
  var stats = getBoardStats();

  // Clear and rebuild
  grid.innerHTML = '';
  for (var i = 0; i < boardState.order.length; i++) {
    var rank = boardState.order[i];
    var state = boardState.states[rank] || 'unknown';
    var tile = document.createElement('div');
    tile.className = 'tile ' + state;
    tile.textContent = rank;
    tile.setAttribute('draggable', 'true');
    tile.setAttribute('data-rank', rank);
    tile.setAttribute('data-index', i);
    if (rank === stats.currentRank) tile.classList.add('current-meeting');
    // Click to cycle
    (function(r) { tile.addEventListener('click', function() { if (!didDrag) cycleTileState(r); didDrag = false; }); })(rank);
    // Drag events
    tile.addEventListener('dragstart', onDragStart);
    tile.addEventListener('dragover', onDragOver);
    tile.addEventListener('dragend', onDragEnd);
    // Touch support
    tile.addEventListener('touchstart', onTouchStart, { passive: false });
    grid.appendChild(tile);
  }

  // Update current meeting indicator
  var currentEl = document.getElementById('boardCurrent');
  if (stats.currentRank !== null) {
    currentEl.innerHTML = 'Next meeting: company <strong>rank ' + stats.currentRank + '</strong> (position ' + (boardState.order.indexOf(stats.currentRank) + 1) + ' in queue)';
    currentEl.className = 'board-current';
  } else {
    currentEl.innerHTML = 'No companies left in the queue. All meetings have been processed or are undecided.';
    currentEl.className = 'board-current no-meeting';
  }
}

// ══════════════════════════════════════════════════════════════
// BOARD — Drag and drop
// ══════════════════════════════════════════════════════════════
var dragTile = null;
var didDrag = false;

function onDragStart(e) {
  dragTile = this;
  didDrag = true;
  this.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain', '');
}

function onDragOver(e) {
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  if (!dragTile || this === dragTile) return;
  var grid = document.getElementById('boardGrid');
  var tiles = Array.prototype.slice.call(grid.children);
  var fromIdx = tiles.indexOf(dragTile);
  var toIdx = tiles.indexOf(this);
  if (fromIdx < 0 || toIdx < 0 || fromIdx === toIdx) return;
  // Move the tile in the DOM — causes live reflow
  if (fromIdx < toIdx) {
    grid.insertBefore(dragTile, this.nextSibling);
  } else {
    grid.insertBefore(dragTile, this);
  }
}

function onDragEnd() {
  if (dragTile) dragTile.classList.remove('dragging');
  // Read final order from DOM and sync to boardState
  var grid = document.getElementById('boardGrid');
  var tiles = grid.children;
  var newOrder = [];
  for (var i = 0; i < tiles.length; i++) {
    newOrder.push(+tiles[i].getAttribute('data-rank'));
    tiles[i].setAttribute('data-index', i);
  }
  boardState.order = newOrder;
  dragTile = null;
  saveState();
  // Update current-meeting highlight and derived values
  updateCurrentHighlight();
  computeDecision();
}

function updateCurrentHighlight() {
  var grid = document.getElementById('boardGrid');
  var tiles = grid.children;
  var stats = getBoardStats();
  for (var i = 0; i < tiles.length; i++) {
    var r = +tiles[i].getAttribute('data-rank');
    tiles[i].classList.toggle('current-meeting', r === stats.currentRank);
  }
  var currentEl = document.getElementById('boardCurrent');
  if (stats.currentRank !== null) {
    currentEl.innerHTML = 'Next meeting: company <strong>rank ' + stats.currentRank + '</strong> (position ' + (boardState.order.indexOf(stats.currentRank) + 1) + ' in queue)';
    currentEl.className = 'board-current';
  } else {
    currentEl.innerHTML = 'No companies left in the queue. All meetings have been processed or are undecided.';
    currentEl.className = 'board-current no-meeting';
  }
}

// Touch-based drag for mobile (live reorder)
var touchState = null;

function onTouchStart(e) {
  var tile = e.currentTarget;
  var touch = e.touches[0];
  touchState = {
    tile: tile,
    startX: touch.clientX,
    startY: touch.clientY,
    longPress: false,
    clone: null,
    timeout: setTimeout(function() {
      touchState.longPress = true;
      didDrag = true;
      touchState.clone = tile.cloneNode(true);
      touchState.clone.style.cssText = 'position:fixed;z-index:9999;pointer-events:none;opacity:0.85;transform:scale(1.15);width:48px;height:48px;display:flex;align-items:center;justify-content:center;font-size:0.9rem;font-weight:700;border-radius:8px;border:2px solid rgba(255,255,255,0.25);background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.6);';
      // Copy state class styles
      var cls = tile.className;
      if (cls.indexOf('waiting') >= 0) { touchState.clone.style.background = '#78520d'; touchState.clone.style.borderColor = '#d4a017'; touchState.clone.style.color = '#FEF3C7'; }
      else if (cls.indexOf('invested') >= 0) { touchState.clone.style.background = '#065f46'; touchState.clone.style.borderColor = '#10B981'; touchState.clone.style.color = '#D1FAE5'; }
      else if (cls.indexOf('canceled') >= 0) { touchState.clone.style.background = '#7f1d1d'; touchState.clone.style.borderColor = '#EF4444'; touchState.clone.style.color = '#FEE2E2'; }
      document.body.appendChild(touchState.clone);
      tile.classList.add('dragging');
      positionClone(touch);
    }, 300)
  };
  document.addEventListener('touchmove', onTouchMove, { passive: false });
  document.addEventListener('touchend', onTouchEnd);
}

function onTouchMove(e) {
  if (!touchState) return;
  var touch = e.touches[0];
  if (!touchState.longPress) {
    var dx = touch.clientX - touchState.startX;
    var dy = touch.clientY - touchState.startY;
    if (Math.abs(dx) + Math.abs(dy) > 10) { clearTimeout(touchState.timeout); cleanupTouch(); }
    return;
  }
  e.preventDefault();
  positionClone(touch);
  // Live reorder: find tile under cursor and move
  var el = document.elementFromPoint(touch.clientX, touch.clientY);
  if (el && el.classList.contains('tile') && el !== touchState.tile) {
    var grid = document.getElementById('boardGrid');
    var tiles = Array.prototype.slice.call(grid.children);
    var fromIdx = tiles.indexOf(touchState.tile);
    var toIdx = tiles.indexOf(el);
    if (fromIdx >= 0 && toIdx >= 0 && fromIdx !== toIdx) {
      if (fromIdx < toIdx) { grid.insertBefore(touchState.tile, el.nextSibling); }
      else { grid.insertBefore(touchState.tile, el); }
    }
  }
}

function onTouchEnd(e) {
  if (!touchState) return;
  clearTimeout(touchState.timeout);
  if (touchState.longPress && touchState.clone) {
    document.body.removeChild(touchState.clone);
    touchState.tile.classList.remove('dragging');
    // Sync order from DOM
    var grid = document.getElementById('boardGrid');
    var tiles = grid.children;
    var newOrder = [];
    for (var i = 0; i < tiles.length; i++) {
      newOrder.push(+tiles[i].getAttribute('data-rank'));
      tiles[i].setAttribute('data-index', i);
    }
    boardState.order = newOrder;
    saveState();
    updateCurrentHighlight();
    computeDecision();
  }
  cleanupTouch();
}

function positionClone(touch) {
  if (touchState && touchState.clone) {
    touchState.clone.style.left = (touch.clientX - 24) + 'px';
    touchState.clone.style.top = (touch.clientY - 24) + 'px';
  }
}

function cleanupTouch() {
  document.removeEventListener('touchmove', onTouchMove);
  document.removeEventListener('touchend', onTouchEnd);
  touchState = null;
}

// ══════════════════════════════════════════════════════════════
// PERSISTENCE — localStorage
// ══════════════════════════════════════════════════════════════
function saveState() {
  var p = getParams();
  var data = { order: boardState.order, states: boardState.states, params: { N: p.N, K: p.K, pMin: p.pMin, pMax: p.pMax, beta: p.beta, lambda: p.lambda } };
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch (e) {}
}

function loadState() {
  try {
    var raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return false;
    var data = JSON.parse(raw);
    if (!data || !data.order || !Array.isArray(data.order) || !data.order.length || !data.states || !data.params) return false;
    // Validate that order contains numbers
    if (typeof data.order[0] !== 'number') { localStorage.removeItem(STORAGE_KEY); return false; }
    // Restore params
    document.getElementById('paramN').value = data.params.N;
    document.getElementById('paramK').value = data.params.K;
    document.getElementById('paramPMin').value = data.params.pMin;
    document.getElementById('paramPMax').value = data.params.pMax;
    document.getElementById('paramBeta').value = data.params.beta;
    document.getElementById('paramLambda').value = data.params.lambda;
    // Update labels
    document.getElementById('pMinLabel').textContent = 'Early dropout chance: ' + (data.params.pMin * 100).toFixed(0) + '%';
    document.getElementById('pMaxLabel').textContent = 'Late dropout chance: ' + (data.params.pMax * 100).toFixed(0) + '%';
    document.getElementById('betaLabel').textContent = 'Dropout acceleration: ' + data.params.beta.toFixed(1);
    document.getElementById('lambdaLabel').textContent = 'Quality premium: ' + data.params.lambda.toFixed(2);
    // Restore board
    boardState.order = data.order;
    boardState.states = data.states;
    return true;
  } catch (e) { return false; }
}

function resetBoard() {
  var N = getParams().N;
  initBoard(N);
  saveState();
  renderBoard();
  computeDecision();
}

// ══════════════════════════════════════════════════════════════
// PORTFOLIO SCORE
// ══════════════════════════════════════════════════════════════
function computePortfolioScore() {
  var p = getParams(); var N = p.N, K = p.K, lambda = p.lambda;
  var stats = getBoardStats();
  if (stats.invested === 0) return null;

  var currentVal = 0;
  for (var i = 0; i < stats.investedRanks.length; i++) currentVal += companyValue(stats.investedRanks[i], N, lambda);

  var bestVal = 0; for (var r = 1; r <= K; r++) bestVal += companyValue(r, N, lambda);
  var worstVal = 0; for (var r = N - K + 1; r <= N; r++) worstVal += companyValue(r, N, lambda);

  if (bestVal <= worstVal) return 5;
  // Piecewise: 0→0, worstVal→5, bestVal→10
  if (currentVal <= 0) return 0;
  if (currentVal <= worstVal) return 5 * currentVal / worstVal;
  return 5 + 5 * (currentVal - worstVal) / (bestVal - worstVal);
}

// ══════════════════════════════════════════════════════════════
// DECISION — reads from board
// ══════════════════════════════════════════════════════════════
function computeDecision() {
  var p = getParams(); var N = p.N, K = p.K, pMin = p.pMin, pMax = p.pMax, beta = p.beta;
  var stats = getBoardStats();
  var invested = stats.invested, canceled = stats.canceled, rank = stats.currentRank;
  var remaining = Math.max(0, N - invested - canceled);
  var picksNeeded = Math.max(0, K - invested);

  // Update derived
  var remEl = document.getElementById('derivedRemaining');
  remEl.textContent = remaining;
  remEl.className = 'd-value' + (remaining < picksNeeded ? ' danger' : remaining < picksNeeded * 1.5 ? ' warn' : '');
  document.getElementById('derivedNeeded').textContent = picksNeeded;
  document.getElementById('derivedUsed').textContent = invested + canceled;

  // Portfolio score
  var score = computePortfolioScore();
  var scoreEl = document.getElementById('derivedScore');
  if (score !== null) { scoreEl.textContent = score.toFixed(1); scoreEl.className = 'd-value highlight'; }
  else { scoreEl.textContent = '\u2014'; scoreEl.className = 'd-value highlight'; }

  if (picksNeeded <= 0) {
    document.getElementById('derivedSupply').textContent = '\u2014';
    return showDecision('neutral', { threshold: 0, slack: 0, urgency: 0 }, 'high',
      'All investment slots are filled. Portfolio complete!', picksNeeded, remaining);
  }
  if (rank === null) {
    document.getElementById('derivedSupply').textContent = '\u2014';
    return showDecision('neutral', { threshold: 0, slack: 0, urgency: 0 }, 'high',
      'No companies left in the queue. All meetings have been processed or are undecided (yellow).', picksNeeded, remaining);
  }

  var r = computeThreshold(N, K, remaining, picksNeeded, pMin, pMax, beta);
  document.getElementById('derivedSupply').textContent = r.es.toFixed(1);

  var accept = rank <= r.threshold;
  var confidence, reason;
  var slackRatio = r.slack / Math.max(picksNeeded, 1);

  if (accept) {
    if (slackRatio < 0.3) {
      confidence = 'high';
      reason = rank > K
        ? 'You are running low on opportunities. With only ' + remaining + ' companies left and ' + picksNeeded + ' investments still needed, it makes sense to invest now even though rank ' + rank + ' is not in your top tier. The quality bar has widened to rank ' + r.threshold + ' to ensure you can complete your portfolio.'
        : 'You are running low on opportunities, but this company (rank ' + rank + ') is within your top ' + K + '. Invest without hesitation \u2014 you need ' + picksNeeded + ' more from ' + remaining + ' remaining.';
    } else if (rank <= K * 0.4) {
      confidence = 'high';
      reason = 'Rank ' + rank + ' is one of the best companies in your pipeline \u2014 a top-tier pick. Easy decision: invest. You also have comfortable breathing room (' + r.slack.toFixed(1) + ' extra meetings expected).';
    } else if (rank <= r.threshold * 0.7) {
      confidence = 'high';
      reason = 'Rank ' + rank + ' is well within your quality bar (accepting up to rank ' + r.threshold + '). This is a strong pick with ' + r.slack.toFixed(1) + ' extra meetings of breathing room ahead.';
    } else {
      confidence = 'medium-high';
      reason = 'Rank ' + rank + ' is within your quality bar (accepting up to rank ' + r.threshold + '). A solid choice worth taking. You have ' + r.slack.toFixed(1) + ' extra meetings of breathing room.';
    }
  } else {
    if (rank > r.threshold * 1.5) {
      confidence = 'high';
      reason = 'Rank ' + rank + ' is well below your quality bar (currently accepting up to rank ' + r.threshold + '). You have plenty of breathing room (' + r.slack.toFixed(1) + ' extra meetings expected) \u2014 wait for a better company.';
    } else if (slackRatio < 0.5) {
      confidence = 'medium';
      reason = 'Rank ' + rank + ' is slightly below your quality bar (rank ' + r.threshold + '). Your breathing room is moderate (' + r.slack.toFixed(1) + ' extra meetings). Pass for now, but keep a close eye on how things develop \u2014 this is a close call.';
    } else {
      confidence = 'high';
      reason = 'You can afford to be selective. Rank ' + rank + ' is below your quality bar (rank ' + r.threshold + '), and you have comfortable breathing room (' + r.slack.toFixed(1) + ' extra meetings expected). Wait for a better opportunity.';
    }
  }
  showDecision(accept ? 'accept' : 'reject', r, confidence, reason, picksNeeded, remaining);
}

function showDecision(mode, result, confidence, reason, picksNeeded, remaining) {
  var box = document.getElementById('decisionBox');
  box.className = 'decision-box ' + mode;
  if (mode === 'accept') {
    document.getElementById('decIcon').textContent = '\u2705';
    document.getElementById('decTitle').textContent = 'INVEST';
  } else if (mode === 'reject') {
    document.getElementById('decIcon').textContent = '\u23F3';
    document.getElementById('decTitle').textContent = 'WAIT FOR BETTER';
  } else {
    document.getElementById('decIcon').textContent = '\u2139\uFE0F';
    document.getElementById('decTitle').textContent = 'NO ACTIVE MEETING';
  }

  var confEl = document.getElementById('decConf');
  var confLabels = { 'high': 'STRONG RECOMMENDATION', 'medium-high': 'GOOD RECOMMENDATION', 'medium': 'CLOSE CALL' };
  confEl.textContent = confLabels[confidence] || '';
  confEl.className = 'conf-' + confidence;
  document.getElementById('decReason').textContent = reason;
  document.getElementById('decThresh').textContent = result.threshold > 0 ? '\u2264 ' + result.threshold : '\u2014';
  var slackEl = document.getElementById('decSlack');
  slackEl.textContent = result.slack !== undefined ? result.slack.toFixed(1) : '\u2014';
  var slackRatio = result.slack / Math.max(picksNeeded, 1);
  slackEl.className = 'value' + (slackRatio < 0.3 ? ' danger' : slackRatio < 0.8 ? ' warn' : '');
  document.getElementById('decSlotsLeft').textContent = remaining;
  var riskEl = document.getElementById('decRisk');
  if (result.urgency >= 0.8) { riskEl.textContent = 'HIGH'; riskEl.className = 'value danger'; }
  else if (result.urgency >= 0.5) { riskEl.textContent = 'MED'; riskEl.className = 'value warn'; }
  else { riskEl.textContent = 'LOW'; riskEl.className = 'value'; }
  document.getElementById('decAlpha').textContent = ALPHA.toFixed(2);
  var safetyPct = Math.min(100, Math.max(0, (1 - result.urgency) * 100));
  document.getElementById('safetyPct').textContent = safetyPct.toFixed(0) + '%';
  var fill = document.getElementById('safetyFill');
  fill.style.width = safetyPct + '%';
  fill.style.background = safetyPct > 60 ? '#10B981' : safetyPct > 30 ? '#F59E0B' : '#EF4444';
}

// ══════════════════════════════════════════════════════════════
// CHARTS
// ══════════════════════════════════════════════════════════════
function drawDropoutChart() {
  var p = getParams(); var N = p.N, pMin = p.pMin, pMax = p.pMax, beta = p.beta;
  var canvas = document.getElementById('dropoutChart'); var ctx = canvas.getContext('2d');
  var dpr = window.devicePixelRatio || 1; var rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * dpr; canvas.height = rect.height * dpr; ctx.scale(dpr, dpr);
  var W = rect.width, H = rect.height, pad = { top: 14, right: 12, bottom: 28, left: 40 };
  var cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom; ctx.clearRect(0, 0, W, H);
  var xOf = function(j) { return pad.left + ((j - 1) / (N - 1)) * cw; };
  var yOf = function(pp) { return pad.top + (1 - pp) * ch; };
  ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth = 1;
  [0, 0.25, 0.5, 0.75].forEach(function(pp) { ctx.beginPath(); ctx.moveTo(pad.left, yOf(pp)); ctx.lineTo(pad.left + cw, yOf(pp)); ctx.stroke(); });
  ctx.fillStyle = '#8B8698'; ctx.font = '10px system-ui, sans-serif'; ctx.textAlign = 'right';
  [0, 0.25, 0.5, 0.75].forEach(function(pp) { ctx.fillText((pp * 100) + '%', pad.left - 4, yOf(pp) + 3); });
  ctx.textAlign = 'center';
  [1, Math.round(N / 2), N].forEach(function(j) { ctx.fillText(j, xOf(j), H - pad.bottom + 14); });
  ctx.fillText('position', pad.left + cw / 2, H - 2);
  ctx.beginPath(); ctx.moveTo(xOf(1), yOf(0));
  for (var j = 1; j <= N; j++) ctx.lineTo(xOf(j), yOf(dropProb(j, N, pMin, pMax, beta)));
  ctx.lineTo(xOf(N), yOf(0)); ctx.closePath();
  var g = ctx.createLinearGradient(0, pad.top, 0, pad.top + ch);
  g.addColorStop(0, 'rgba(239,68,68,0.2)'); g.addColorStop(1, 'rgba(239,68,68,0.01)'); ctx.fillStyle = g; ctx.fill();
  ctx.beginPath(); for (var j = 1; j <= N; j++) { var x = xOf(j), y = yOf(dropProb(j, N, pMin, pMax, beta)); j === 1 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); }
  ctx.strokeStyle = '#EF4444'; ctx.lineWidth = 2; ctx.stroke();
  [1, N].forEach(function(j) { var pp = dropProb(j, N, pMin, pMax, beta); ctx.beginPath(); ctx.arc(xOf(j), yOf(pp), 3, 0, Math.PI * 2); ctx.fillStyle = '#EF4444'; ctx.fill(); });
  ctx.font = 'bold 10px system-ui, sans-serif'; ctx.fillStyle = '#EF4444';
  ctx.textAlign = 'left'; ctx.fillText((dropProb(1, N, pMin, pMax, beta) * 100).toFixed(0) + '%', xOf(1) + 6, yOf(dropProb(1, N, pMin, pMax, beta)) - 5);
  ctx.textAlign = 'right'; ctx.fillText((dropProb(N, N, pMin, pMax, beta) * 100).toFixed(0) + '%', xOf(N) - 6, yOf(dropProb(N, N, pMin, pMax, beta)) - 5);
}
function drawValueChart() {
  var p = getParams(); var N = p.N, lambda = p.lambda;
  var canvas = document.getElementById('valueChart'); var ctx = canvas.getContext('2d');
  var dpr = window.devicePixelRatio || 1; var rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * dpr; canvas.height = rect.height * dpr; ctx.scale(dpr, dpr);
  var W = rect.width, H = rect.height, pad = { top: 14, right: 12, bottom: 28, left: 40 };
  var cw = W - pad.left - pad.right, ch = H - pad.top - pad.bottom; ctx.clearRect(0, 0, W, H);
  var vMax = companyValue(1, N, lambda);
  var xOf = function(r) { return pad.left + ((r - 1) / (N - 1)) * cw; };
  var yOf = function(v) { return pad.top + (1 - v / vMax) * ch; };
  ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth = 1;
  [0, 0.25, 0.5, 0.75, 1].forEach(function(f) { ctx.beginPath(); ctx.moveTo(pad.left, yOf(f * vMax)); ctx.lineTo(pad.left + cw, yOf(f * vMax)); ctx.stroke(); });
  ctx.fillStyle = '#8B8698'; ctx.font = '10px system-ui, sans-serif'; ctx.textAlign = 'right';
  [0, 0.25, 0.5, 0.75, 1].forEach(function(f) { ctx.fillText((f * vMax).toFixed(0), pad.left - 4, yOf(f * vMax) + 3); });
  ctx.textAlign = 'center';
  [1, Math.round(N / 4), Math.round(N / 2), Math.round(N * 3 / 4), N].forEach(function(r) { ctx.fillText(r, xOf(r), H - pad.bottom + 14); });
  ctx.fillText('rank', pad.left + cw / 2, H - 2);
  ctx.beginPath(); ctx.moveTo(xOf(1), yOf(0));
  for (var r = 1; r <= N; r++) ctx.lineTo(xOf(r), yOf(companyValue(r, N, lambda)));
  ctx.lineTo(xOf(N), yOf(0)); ctx.closePath();
  var g = ctx.createLinearGradient(0, pad.top, 0, pad.top + ch);
  g.addColorStop(0, 'rgba(16,185,129,0.2)'); g.addColorStop(1, 'rgba(16,185,129,0.01)'); ctx.fillStyle = g; ctx.fill();
  ctx.beginPath(); for (var r = 1; r <= N; r++) { var x = xOf(r), y = yOf(companyValue(r, N, lambda)); r === 1 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); }
  ctx.strokeStyle = '#10B981'; ctx.lineWidth = 2; ctx.stroke();
  [1, N].forEach(function(r) { ctx.beginPath(); ctx.arc(xOf(r), yOf(companyValue(r, N, lambda)), 3, 0, Math.PI * 2); ctx.fillStyle = '#10B981'; ctx.fill(); });
  ctx.font = 'bold 10px system-ui, sans-serif'; ctx.fillStyle = '#10B981';
  ctx.textAlign = 'left'; ctx.fillText(companyValue(1, N, lambda).toFixed(0), xOf(1) + 6, yOf(companyValue(1, N, lambda)) - 5);
  ctx.textAlign = 'right'; ctx.fillText(companyValue(N, N, lambda).toFixed(1), xOf(N) - 6, yOf(companyValue(N, N, lambda)) - 8);
  ctx.font = '10px system-ui, sans-serif'; ctx.fillStyle = '#F59E0B'; ctx.textAlign = 'center';
  ctx.fillText('#1 is ' + (companyValue(1, N, lambda) / companyValue(N, N, lambda)).toFixed(0) + '\u00D7 #' + N, pad.left + cw / 2, pad.top + 12);
}
function drawChartsIfOpen() {
  var d = document.querySelector('.charts-details');
  if (d && d.open) { drawDropoutChart(); drawValueChart(); }
}

// ══════════════════════════════════════════════════════════════
// MATH
// ══════════════════════════════════════════════════════════════
function renderMath() {
  if (typeof katex === 'undefined') return;
  var formulas = {
    math1: '\\text{remaining} = N - i - c \\qquad \\text{needs} = K - i',
    math2: 'p(j) = p_{\\min} + (p_{\\max} - p_{\\min}) \\cdot \\frac{e^{\\,\\beta\\, j/n} - 1}{e^{\\,\\beta} - 1}',
    math3: '\\mathbb{E}[\\,m_{\\text{future}}\\,] = \\sum_{j=1}^{\\,\\text{remaining}-1} \\bigl(1 - p(j)\\bigr)',
    math4: '\\text{slack} = \\mathbb{E}[\\,m_{\\text{future}}\\,] - (\\text{needs} - 1)',
    math5: '\\theta = \\min\\!\\Bigl(N,\\;\\max\\!\\bigl(\\text{needs},\\;\\Bigl\\lceil \\frac{N \\cdot \\text{needs}}{\\text{needs} + \\text{slack} \\cdot \\alpha} \\Bigr\\rceil\\bigr)\\Bigr)',
    mathVal: 'v(r) = e^{\\,\\lambda\\,(N - r)}',
    math6: '\\alpha^* = \\underset{\\alpha \\,\\in\\, [0.2,\\, 3.0]}{\\arg\\max} \\;\\; \\mathbb{E}\\!\\left[\\sum_{r \\,\\in\\, \\text{portfolio}} v(r)\\right] \\times\\; \\Pr[\\text{complete}]',
    math7: '\\text{Accept company with rank } r \\iff r \\leq \\theta'
  };
  var ids = Object.keys(formulas);
  for (var i = 0; i < ids.length; i++) {
    var el = document.getElementById(ids[i]);
    if (el) try { katex.render(formulas[ids[i]], el, { displayMode: true, throwOnError: false }); } catch (e) { el.textContent = formulas[ids[i]]; }
  }
}

// ══════════════════════════════════════════════════════════════
// COLLAPSIBLES
// ══════════════════════════════════════════════════════════════
function setupCollapsibles() {
  var mathD = document.querySelector('.math-details');
  if (mathD) mathD.addEventListener('toggle', function() {
    var h = mathD.querySelector('.toggle-hint'); if (h) h.textContent = mathD.open ? 'Hide formulas' : 'Show formulas';
    if (mathD.open) renderMath();
  });
  var introD = document.querySelector('.intro-details');
  if (introD) introD.addEventListener('toggle', function() {
    var h = introD.querySelector('.intro-toggle-hint'); if (h) h.textContent = introD.open ? 'Hide' : 'Show explanation';
  });
  var chartsD = document.querySelector('.charts-details');
  if (chartsD) chartsD.addEventListener('toggle', function() {
    var h = chartsD.querySelector('.charts-toggle-hint'); if (h) h.textContent = chartsD.open ? 'Hide settings' : 'Show settings';
    if (chartsD.open) { drawDropoutChart(); drawValueChart(); }
  });
}

// ══════════════════════════════════════════════════════════════
// PARAMETER CHANGES
// ══════════════════════════════════════════════════════════════
function onParamsChanged() {
  document.getElementById('pMinLabel').textContent = 'Early dropout chance: ' + (+document.getElementById('paramPMin').value * 100).toFixed(0) + '%';
  document.getElementById('pMaxLabel').textContent = 'Late dropout chance: ' + (+document.getElementById('paramPMax').value * 100).toFixed(0) + '%';
  document.getElementById('betaLabel').textContent = 'Dropout acceleration: ' + (+document.getElementById('paramBeta').value).toFixed(1);
  document.getElementById('lambdaLabel').textContent = 'Quality premium: ' + (+document.getElementById('paramLambda').value).toFixed(2);
  var N = getParams().N;
  resizeBoard(N);
  renderBoard();
  drawChartsIfOpen();
  saveState();
  if (calibrationTimer) clearTimeout(calibrationTimer);
  calibrationTimer = setTimeout(function() { calibrateAlpha(); }, 300);
  computeDecision();
}

// ══════════════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', function() {
  // Load saved state or init fresh
  if (!loadState()) { initBoard(getParams().N); }

  // Wire params
  ['paramN', 'paramK', 'paramPMin', 'paramPMax', 'paramBeta', 'paramLambda'].forEach(function(id) {
    document.getElementById(id).addEventListener('input', onParamsChanged);
  });

  // Reset button
  document.getElementById('resetBoard').addEventListener('click', resetBoard);

  // Collapsibles
  setupCollapsibles();

  // Resize
  window.addEventListener('resize', drawChartsIfOpen);

  // Render board and compute
  renderBoard();
  calibrateAlpha();
});
</script>
