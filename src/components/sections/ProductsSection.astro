<style>
  .products {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .product {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-height: 340px;
    padding: 2rem;
    background: rgba(26, 26, 26, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(243, 158, 11, 0.16);
    border-radius: 16px;
    text-decoration: none;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  /* Top accent bar */
  .accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-gold), var(--color-gold-light));
  }

  .bg-icon {
    position: absolute;
    width: 9rem;
    height: 9rem;
    opacity: 0.08;
    right: -1.5rem;
    top: 54%;
    transform: translateY(-50%);
    pointer-events: none;
    user-select: none;
    color: var(--color-gold);
  }

  .product-badge {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    flex: none;
    border-radius: 12px;
    border: 1px solid rgba(243, 158, 11, 0.3);
    background: rgba(245, 158, 11, 0.07);
    color: var(--color-gold);
  }

  .product-badge svg {
    width: 26px;
    height: 26px;
  }

  .product-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .eyebrow {
    font-family: var(--font-display);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-gold-light);
  }

  .product h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.3rem;
    letter-spacing: 0.5px;
    line-height: 1.3;
    color: var(--color-text);
  }

  .product p {
    color: var(--color-text-muted);
    line-height: 1.6;
    font-size: 0.98rem;
  }

  .tags {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    padding: 0.25rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    line-height: 1.4;
  }

  .product-cta {
    position: relative;
    z-index: 1;
    font-weight: 600;
    color: var(--color-gold-light);
    font-size: 0.95rem;
    transition: transform 0.3s ease;
  }

  /* Purple accent on the middle card — palette variety without the gradient */
  .product:nth-child(2) {
    border-color: rgba(168, 85, 247, 0.18);
  }

  .product:nth-child(2) .accent {
    background: linear-gradient(90deg, var(--color-purple), var(--color-purple-light));
  }

  .product:nth-child(2) .bg-icon,
  .product:nth-child(2) .eyebrow,
  .product:nth-child(2) .product-cta {
    color: var(--color-purple-light);
  }

  .product:nth-child(2) .product-badge {
    border-color: rgba(168, 85, 247, 0.3);
    background: rgba(168, 85, 247, 0.07);
    color: var(--color-purple-light);
  }

  @media (hover: hover) {
    .product:hover {
      transform: translateY(-6px);
      border-color: rgba(243, 158, 11, 0.4);
      box-shadow: 0 18px 50px rgba(245, 158, 11, 0.12);
    }

    .product:nth-child(2):hover {
      border-color: rgba(168, 85, 247, 0.42);
      box-shadow: 0 18px 50px rgba(147, 51, 234, 0.12);
    }

    .product:hover .product-cta {
      transform: translateX(4px);
    }
  }

  @media (max-width: 768px) {
    .products {
      grid-template-columns: 1fr;
    }
  }
</style>
