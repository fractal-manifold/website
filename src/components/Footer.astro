---
const path = Astro.url.pathname;
const isSpanish = path.startsWith('/aviso-legal') || path.startsWith('/politica-privacidad');

const labels = isSpanish
  ? { legal: 'Aviso Legal', privacy: 'Política de Privacidad', rights: 'Todos los derechos reservados.' }
  : { legal: 'Legal Notice', privacy: 'Privacy Policy', rights: 'All rights reserved.' };

const legalHref = isSpanish ? '/aviso-legal' : '/legal-notice';
const privacyHref = isSpanish ? '/politica-privacidad' : '/privacy-policy';
---

<footer>
  <div class="container">
    <div class="footer-bottom">
      <p>
        &copy; {new Date().getFullYear()} <span class="brand">Fractal Manifold</span>. {labels.rights}
        <span class="sep" aria-hidden="true">·</span>
        <a href={legalHref}>{labels.legal}</a>
        <span class="sep" aria-hidden="true">·</span>
        <a href={privacyHref}>{labels.privacy}</a>
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-bg-secondary);
    border-top: 1px solid rgba(243, 158, 11, 0.1);
    margin-top: 5rem;
  }

  .footer-bottom {
    padding: 2rem 0;
    text-align: center;
  }

  .footer-bottom p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .brand {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 500;
  }

  .sep {
    margin: 0 0.5rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .footer-bottom a {
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }

  .footer-bottom a:hover {
    color: var(--color-gold);
  }
</style>
